# This file includes global variables that will be available inside your project
# 1. In the front end code you can access this variables like this: console.log(import.meta.env.VARIABLE_NAME)
# 1. In the back end code you access the variable by importing os and then typing print(os.getenv('VARIABLE_NAME'))

# Back-End Variables

# Option A: Local SQLite (for individual dev without Supabase)
# DATABASE_URL=sqlite:///db.sqlite3

# Option B: Supabase PostgreSQL (shared team database — recommended)
# Get password from: Supabase Dashboard → Project Settings → Database → Connection string
DATABASE_URL=postgresql://postgres.bjuugpwvwfnqozhrmjgn:[YOUR-DB-PASSWORD]@aws-1-eu-west-1.pooler.supabase.com:5432/postgres

FLASK_APP_KEY="any key works"
FLASK_APP=src/app.py
FLASK_DEBUG=1
DEBUG=TRUE

# Mail (Gmail SMTP — set real credentials for email sending)
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_SUPPRESS_SEND=1

# MetaAPI (admin master token — never expose to frontend)
METAAPI_TOKEN=your-metaapi-token

# Front-End Variables
VITE_BASENAME=/
